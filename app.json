{
  "expo": {
    "name": "Zenova",
    "slug": "MeditationApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/screen.png",
    "scheme": "meditationapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/screen.png",
      "bundleIdentifier": "com.sksatyam.MeditationApp"
    },
    "android": {
      "icon": "./assets/images/screen.png",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sksatyam.MeditationApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/screen.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/screen.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1B4332",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b862d3d8-cde9-4356-83a0-bf85f4365634"
      }
    }
  }
}
